# 复制为 .env 并填入你自己的 Key
# 默认用 Gemini(海外);国内用不了 Gemini 的,改填下面「用国内/其它模型」那一段。
# 在 https://aistudio.google.com/apikey 申请
GEMINI_API_KEY=AIza...

# ───────────────────────────────────────────────────────────────────────────
# 用国内 / 其它模型(可选;不填则默认走上面的 Gemini)
# 任意 OpenAI 兼容供应商,换 base_url 即可。官方实测背书:Gemini、GLM;其余为「理论兼容,自行验证」。
#
# ① 文本 + 结构化(所有纯文本 skill)
#   preset 名:glm / kimi / deepseek / qwen / ernie / doubao / minimax / openai
# LOEVENT_TEXT_PROVIDER=glm
# LOEVENT_TEXT_MODEL=glm-4.6                 # 按你账号的实际模型名填
# LOEVENT_TEXT_API_KEY=你的文本模型key
# LOEVENT_TEXT_BASE_URL=                     # 仅自定义端点/网关(OneAPI/OpenRouter)时填;用 preset 就留空
#
# ② 联网调研(trends/guests/company/budget):混合——有原生搜索的家(Qwen/GLM/ERNIE)默认走原生,
#    没原生的(DeepSeek/Kimi/豆包)需配下面的外部搜索;显式配了会强制统一走外部(覆盖原生)
# LOEVENT_SEARCH_PROVIDER=bocha              # bocha(国内,免费 1000 次)/ tavily(海外)/ none
# LOEVENT_SEARCH_API_KEY=你的搜索key
# LOEVENT_ALLOW_UNGROUNDED=                  # 设 1 = 接受无实时来源(可能过时/编造);默认不设 = 严格
#   注:既没原生、也没配外部 → 默认报错中止(避免无来源编造)
#
# ③ 海报文生图
# LOEVENT_IMAGE_PROVIDER=doubao              # doubao(豆包,4K)/ cogview(智谱,cogview-3-flash 免费)/ openai
# LOEVENT_IMAGE_MODEL=你的文生图模型名
# LOEVENT_IMAGE_API_KEY=你的图像key
# LOEVENT_IMAGE_SIZE=                        # 可选,如 1024x1536 控海报比例;留空用供应商默认尺寸
#
# ④ 海报「文字可编辑」的消字(可选;不配则退到 Gemini 或本地 erase 兜底)
# LOEVENT_IMAGE_EDIT_PROVIDER=qwen           # qwen(qwen-image-edit via DashScope,指令式消字)
# LOEVENT_IMAGE_EDIT_MODEL=qwen-image-edit
# LOEVENT_IMAGE_EDIT_API_KEY=你的DashScope key
#
# ⑤ 海报「文字可编辑」的文字定位(可选;Google OCR 用不了时用国产多模态 VL 估框)
#   不配则:有 GCV(GOOGLE_APPLICATION_CREDENTIALS)走 GCV 精确,再没有就看图估位
# LOEVENT_OCR_PROVIDER=qwen-vl               # qwen-vl(DashScope)/ glm-4v(智谱)/ 自定义 base_url
# LOEVENT_OCR_MODEL=qwen-vl-max
# LOEVENT_OCR_API_KEY=你的VL模型key
#   注:VL 估的框精度不及 GCV,在 HTML 编辑器里拖准即可
# ───────────────────────────────────────────────────────────────────────────

# 可选:仅「海报文字可编辑」流程(OCR 取文字框)需要——指向 Google Cloud Vision 服务账号 JSON 的路径
# (service account,独立于 GEMINI_API_KEY)。该 JSON 是密钥,放仓库外、别提交。不填不影响普通出图。
# GOOGLE_APPLICATION_CREDENTIALS=/绝对路径/你的-vision-service-account.json

# 可选:海报文字渲染用的中文字体路径(缺省自动探测系统中文字体)。
# LOEVENT_POSTER_FONT=/绝对路径/某字体.otf

# 可选:指定工作目录。缺省把产物写进**系统临时沙箱**(loevent-workspace/,用完即清,
# 不长期落在项目目录)。只有想把产物固定留在某处时才设这个(设了就不再自动清整盘,
# 只清 loevent 自己的产物)。
# LOEVENT_WORKDIR=./my-event

# 可选:给临时沙箱再分一层子目录,便于多个活动并行时互不串档(如按活动名/会话)。
# LOEVENT_SESSION=web3-midyear
